# Server
HOST=0.0.0.0
PORT=8000
API_KEY=                               # required for all endpoints
ALLOWED_REPO_DOMAINS=github.com,gitlab.com
MAX_REQUEST_BODY_MB=10

# Repository
REPOS_CACHE_DIR=./repos_cache
SHALLOW_CLONE=true

# gkg
GKG_PATH=gkg
GKG_SERVER_PORT=27495
GKG_ENABLE_REINDEXING=true
GKG_INDEX_TIMEOUT=300
GKG_QUERY_TIMEOUT=30

# LLM
LLM_PROVIDER=fpt_cloud
LLM_MODEL=GLM-4.5
LLM_API_KEY=
LLM_BASE_URL=https://mkp-api.fptcloud.com
LLM_MAX_CONCURRENT=5
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000
LLM_RETRY_COUNT=2
LLM_TIMEOUT=60

# Analysis
FP_CONFIDENCE_THRESHOLD=0.8
MAX_FINDINGS_PER_REQUEST=200
MAX_CONTEXT_LINES=20

# Cache
RESULT_CACHE_ENABLED=true
RESULT_CACHE_DIR=./cache
RESULT_CACHE_TTL_HOURS=24

# Index Registry
INDEX_REGISTRY_PATH=./index_registry.json

# LangSmith Observability (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Semgrep_FP_identifier

# Logging
LOG_LEVEL=INFO
LOG_FILE=
